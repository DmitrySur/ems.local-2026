{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "awcodes/filament-badgeable-column": "^2.3",
        "awcodes/filament-table-repeater": "^3.0",
        "blade-ui-kit/blade-heroicons": "^2.3",
        "codeat3/blade-radix-icons": "^1.7",
        "filament/filament": "^3.2",
        "guava/filament-clusters": "^1.1",
        "guzzlehttp/guzzle": "^7.2",
        "husam-tariq/filament-timepicker": "^3.0",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.8",
        "maatwebsite/excel": "^3.1",
        "malzariey/filament-daterangepicker-filter": "3.2.2",
        "opcodesio/log-viewer": "^3.6",
        "phpoffice/phpword": "^1.2",
        "phpsa/filament-authentication": "^3.2",
        "saade/blade-iconsax": "^1.1",
        "spatie/eloquent-sortable": "^4.2",
        "spatie/laravel-data": "^4.21",
        "spatie/laravel-permission": "^6.3",
        "spatie/laravel-query-builder": "^6.4",
        "stevebauman/purify": "^6.3",
        "tightenco/ziggy": "^2.6",
        "wildside/userstamps": "^2.3"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.10",
        "fakerphp/faker": "^1.9.1",
        "laravel-lang/common": "^6.1",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.0",
        "spatie/laravel-model-info": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
